<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Lumira Registration Form</title>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

body{
    margin:0;
    font-family:Arial, sans-serif;
    background:whitesmoke;
}

/* TOP HEADER */

.top-header{
    background:black;
    color:white;
    display:flex;
    justify-content:space-between;
    padding:8px 25px;
    font-size:14px;
}

.top-header a{
    color:white;
    text-decoration:none;
}

/* MAIN HEADER */

.header{
    background:whitesmoke;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:15px 30px;
    border-bottom:1px solid lightgray;
}

.logo{
    color:purple;
    font-size:30px;
    font-weight:bold;
}

.header .logo:hover{
    background:black;
    color:white;
    border-radius:5px;
    
}

.header-right a{
    text-decoration:none;
    color:black;
    margin-left:20px;
    font-size:15px;
    transition:0.3s;
    padding:8px 12px;
    border-radius:5px;
}

.header-right a:hover{
    background:black;
    color:white;
}

/* CATEGORY BAR */

.categorybar{
    display:flex;
    justify-content:space-between;
    align-items:center;
    background:rgb(90, 26, 90);
    padding:12px 25px;
}

.category-left{
    display:flex;
    gap:22px;
}

.category-left a{
    color:white;
    text-decoration:none;
    font-size:15px;
    transition:0.3s;
}

.category-left a:hover{
    color:rgb(180,180,93);
    transform:scale(1.1);
}

.searchbar{
    display:flex;
}

.searchbar input{
    padding:8px;
    border:none;
    outline:none;
    border-radius:5px 0 0 5px;
}

.searchbar button{
    padding:8px 15px;
    border:none;
    background:rgb(180,180,93);
    color:white;
    border-radius:0 5px 5px 0;
    cursor:pointer;
    transition:0.3s;
}

.searchbar button:hover{
    background:white;
    color:purple;
}

/* FORM */

.form-container{
    width:420px;
    background:white;
    margin:60px auto;
    padding:35px;
    border-radius:18px;
    box-shadow:0 0 18px rgba(0,0,0,0.15);
    border-top:6px solid purple;
}

.form-container h2{
    text-align:center;
    margin-bottom:25px;
    color:black;
    font-size:32px;
}

/* INPUTS */

.input-box{
    margin-bottom:18px;
}

.input-box label{
    display:block;
    margin-bottom:8px;
    font-weight:bold;
    color:black;
}

.input-box input,
.input-box select{
    width:100%;
    padding:12px;
    border:1px solid lightgray;
    border-radius:8px;
    outline:none;
    font-size:15px;
    box-sizing:border-box;
    transition:0.3s;
}

.input-box input:focus,
.input-box select:focus{
    border-color:black;
    transform:scale(1.02);
    box-shadow:0 0 8px rgba(128,0,128,0.2);
}

/* BUTTON */

.register-btn{
    width:100%;
    padding:12px;
    border:none;
    background:rgb(90, 26, 90);
    color:white;
    font-size:17px;
    border-radius:8px;
    cursor:pointer;
    transition:0.3s;
}

.register-btn:hover{
    background:black;
    color:white;
    transform:scale(1.03);
}

/* DIVIDER */

.divider{
    display:flex;
    align-items:center;
    margin:25px 0;
}

.divider::before,
.divider::after{
    content:"";
    flex:1;
    height:1px;
    background:lightgray;
}

.divider span{
    margin:0 10px;
    color:gray;
}

/* SOCIAL LOGIN */

.social-login{
    display:flex;
    flex-direction:column;
    gap:15px;
}

.social-btn{
    width:100%;
    padding:12px;
    border:1px solid lightgray;
    border-radius:8px;
    background:white;
    cursor:pointer;
    display:flex;
    align-items:center;
    gap:18px;
    font-size:15px;
    transition:0.3s;
}

.social-btn:hover{
    background:whitesmoke;
    transform:scale(1.03);
    border-color:black;
}

.social-btn i{
    margin-left:10px;
    font-size:18px;
    color:black;
}

/* BOTTOM TEXT */

.bottom-text{
    text-align:center;
    margin-top:20px;
    font-size:14px;
}

.bottom-text a{
    color:maroon;
    text-decoration:none;
    font-weight:bold;
}

.bottom-text a:hover{
    color:black;
}

</style>
</head>

<body>

<!-- TOP HEADER -->

<div class="top-header">

    <div>
        <a href="#">Track your order</a>
    </div>

    <div>
        <a href="#">Call +12345 879 541</a>
    </div>

    <div>
        ENG | USD
    </div>

</div>

<!-- MAIN HEADER -->

<div class="header">

    <div class="logo">Lumira</div>

    <div class="header-right">
        <a href="#">Login</a>
        <a href="#">Help</a>
    </div>

</div>

<!-- CATEGORY BAR -->

<div class="categorybar">

    <div class="category-left">
        <a href="#">Skincare</a>
        <a href="#">Makeup</a>
        <a href="#">Haircare</a>
        <a href="#">Fragrance</a>
        <a href="#">New Arrivals</a>
        <a href="#">Offers</a>
    </div>

    <div class="searchbar">
        <input type="text" placeholder="Search here...">
        <button>Search</button>
    </div>

</div>

<!-- REGISTRATION FORM -->

<div class="form-container">

    <h2>Create Account</h2>

    <form>

        <div class="input-box">
            <label>Full Name</label>
            <input type="text" placeholder="Enter your full name" required>
        </div>

        <div class="input-box">
            <label>Email</label>
            <input type="email" placeholder="Enter your email" required>
        </div>

        <div class="input-box">
            <label>Password</label>
            <input type="password" placeholder="Create password" required>
        </div>

        <div class="input-box">
            <label>Gender</label>

            <select required>
                <option value="">Select Gender</option>
                <option>Male</option>
                <option>Female</option>
                <option>Other</option>
            </select>
        </div>

        <div class="input-box">
            <label>Mobile Number</label>
            <input type="tel" placeholder="Enter mobile number" required>
        </div>

        <button class="register-btn">
            Register
        </button>

    </form>

    <div class="divider">
        <span>OR</span>
    </div>

    <!-- SOCIAL LOGIN -->

    <div class="social-login">

        <button class="social-btn">
            <i class="fa-brands fa-google"></i>
            Register with Google
        </button>

        <button class="social-btn">
            <i class="fa-brands fa-apple"></i>
            Register with Apple ID
        </button>

        <button class="social-btn">
            <i class="fa-brands fa-facebook-f"></i>
            Register with Facebook
        </button>

    </div>

    <div class="bottom-text">
        Already have an account?
        <a href="#">Login</a>
    </div>

</div>

</body>
</html>
