<!DOCTYPE html>
<html>

<head>
  <title>Web Page</title>

  <style>

    body{
      margin: 0;
    }

    .top-header {
      display: flex;
      background-color: black;
      align-items: center;
      padding: 5px 20px;
    }

    .left {
      flex: 1;
      text-align: left;
    }

    .center {
      flex: 1;
      text-align: center;
    }

    .right {
      flex: 1;
      color: beige;
      text-align: right;
    }

    .top-header a {
      color: white;
      text-decoration: none;
    }

    .header {
      background-color: lightgray;
      overflow: hidden;
      padding: 10px 20px;
      font-family: Arial, sans-serif;
    }

    .header .logo {
      color: white;
      font-size: 22px;
      font-weight: bold;
      text-decoration: none;
      float: left;
      padding: 12px 16px;
      cursor: pointer;
      display: block;
    }

    .header .logo:hover {
      background-color: white;
      color: black;
      border-radius: 5px;
    }

    
    .header-right {
      float: right;
    }

    .header-right a {
      display: inline-block;
      color: white;
      text-align: center;
      padding: 12px 16px;
      text-decoration: none;
      font-size: 17px;
    }

    .header-right a:hover {
      background-color: white;
      color: black;
      border-radius: 5px;
    }

    .header-right a.active {
      background-color: lightgreen;
      color: white;
      border-radius: 5px;
    }

  </style>
</head>

<body>

  <header>

    <div class="top-header">

      <div class="left">
        <a href="#">Track your order</a>
      </div>

      <div class="center">
        <a href="tel:+12345879541">Call +12345 879 541</a>
      </div>

      <div class="right">
        <span>ENG | </span>
        <span>USD</span>
      </div>

    </div>

  </header>


  <div class="header">

    <a href="#default" class="logo">Company Logo</a>

    <div class="header-right">
      <a class="active" href="#home">Home</a>
      <a href="#about">About</a>
      <a href="#contact">Contact</a>
    </div>

  </div>

</body>

</html>
