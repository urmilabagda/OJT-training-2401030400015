<!DOCTYPE html>
<html>

<head>
  <title>Web Page</title>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

  <style>

    body {
      margin: 0;
      background-color: whitesmoke;
      font-family: Arial, Helvetica, sans-serif;
    }

    /* ================= TOP HEADER ================= */

    .top-header {
      display: flex;
      background-color: black;
      align-items: center;
      padding: 1px 0px;
    }

    .left {
      flex: 1;
      color: white;
      text-align: left;
    }

    .center {
      flex: 1;
      color: white;
      text-align: center;
    }

    .right {
      flex: 1;
      color: white;
      text-align: right;
    }

    .top-header a {
      color: white;
      text-decoration: none;
    }

    /* ================= MAIN HEADER ================= */

    .header {
       background-image:linear-gradient(to right , rgb(230, 224, 232), rgb(127, 73, 138));;
      overflow: hidden;
      padding: 9px 12px;
    }

    .header .logo {
      color: purple;
      font-size: 22px;
      font-weight: bold;
      text-decoration: none;
      float: left;
      padding: 12px 15px;
      cursor: pointer;
      display: block;
    }

    .header .logo:hover {
      background-color: black;
      color: white;
      border-radius: 5px;
    }

    .header-right {
      float: right;
    }

    .header-right a {
      display: inline-block;
      color: white;
      text-align: center;
      padding: 10px 12px;
      text-decoration: none;
      font-size: 12px;
    }

    .header-right a:hover {
      background-color: black;
      color: white;
      border-radius: 5px;
    }

    .header-right a.active {
      background-color: black;
      color: white;
      border-radius: 5px;
    }

    /* ================= CATEGORY BAR ================= */

    .categorybar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      background-color: rgb(90, 26, 90);
      padding: 7px 15px;
    }

    .categorybar .left {
      display: flex;
      align-items: center;
      gap: 25px;
    }

    .categorybar .left a {
      color: white;
      text-decoration: none;
      font-size: 12px;
      transition: 0.3s;
    }

    .categorybar .left a:hover,
.categorybar .left a.active-category{
    
    color: rgb(180, 180, 93);
    border-radius:5px;
    transform: scale(1.05);
}
      .categorybar .left a.active-category{
    color: rgb(180, 180, 93);
    padding:8px 14px;
    border-radius:5px;
    font-weight:bold;
     }

    .categorybar .center {
      display: flex;
      align-items: center;
      justify-content: center;
      flex-grow: 1;
    }

    .searchbar {
      display: flex;
      align-items: center;
    }

    .searchbar input {
      padding: 7px;
      border: none;
      outline: none;
      border-radius: 4px 0 0 4px;
    }

    .searchbar button {
      padding: 7px 12px;
      border: none;
      background-color: rgb(180, 180, 93);
      color: white;
      cursor: pointer;
      border-radius: 0 4px 4px 0;
    }

    .searchbar button:hover {
      background-color: white;
      color: purple;
    }

    .categorybar .right {
      display: flex;
      align-items: center;
      gap: 20px;
      justify-content: flex-end;
      flex-shrink: 0;
    }

    .categorybar .right a {
      color: white;
      text-decoration: none;
      font-size: 18px;
      transition: 0.3s;
    }

    .categorybar .right a:hover {
      color: red;
      transform: scale(1.2);
    }

    /* ================= CATEGORY PAGE ================= */

    .main-section {
      display: flex;
      padding: 20px;
      gap: 20px;
    }

    /* LEFT CATEGORY */

    .sidebar {
      width: 250px;
      background-color: white;
      padding: 20px;
      border-radius: 10px;
      box-shadow: 0px 0px 10px lightgray;
      height: fit-content;
    }

    .sidebar h2 {
      color: purple;
      margin-bottom: 20px;
    }

    .sidebar a {
      display: block;
      text-decoration: none;
      color: black;
      padding: 12px;
      border-radius: 5px;
      margin-bottom: 8px;
      transition: 0.3s;
    }

    /* ACTIVE CATEGORY */

    .sidebar a.active {
      background-color: purple;
      color: white;
      font-weight: bold;
    }

    .sidebar a:hover {
      background-color: rgb(230, 230, 230);
      color: purple;
      padding-left: 18px;
    }

    /* PRODUCT SECTION */

    .products {
      flex: 1;
    }

    .products h2 {
      color: purple;
      margin-bottom: 20px;
    }

    .product-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }

    .card {
      background-color: white;
      padding: 15px;
      border-radius: 12px;
      text-align: center;
      box-shadow: 0px 0px 10px lightgray;
      transition: 0.3s;
    }

    .card:hover {
      transform: translateY(-5px);
    }

    .card img {
      width: 100%;
      height: 220px;
      object-fit: cover;
      border-radius: 10px;
    }

    .card h3 {
      margin-top: 10px;
      color: black;
    }

    .price {
      color: black;
      font-weight: bold;
      font-size: 18px;
    }

    .btn {
      color: white;
      border: none;
      padding: 10px 18px;
      border-radius: 5px;
      cursor: pointer;
      margin-top: 10px;
      background-image:linear-gradient(to right , rgb(113, 37, 134), rgb(211, 211, 202));
    }

    .btn:hover {
      padding:15px 20px;
      cursor: pointer;
    }

  </style>
</head>

<body>

